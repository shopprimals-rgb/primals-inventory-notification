# Required
WAREHANCE_API_KEY=your_warehance_api_key
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Lead time for ALL products, in days (sets the CRITICAL line)
LEAD_TIME_DAYS=120

# Optional tuning (defaults shown)
SAFETY_STOCK_DAYS=30
# REORDER_POINT_DAYS=        # leave blank = LEAD_TIME_DAYS + SAFETY_STOCK_DAYS
MEDIUM_WINDOW_DAYS=30
VELOCITY_WINDOW_DAYS=30       # use 30/60/90 day sales for velocity
CHECK_INTERVAL_SECONDS=43200  # 12 hours
